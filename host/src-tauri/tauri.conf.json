{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Casual RAS Host",
  "version": "0.0.0",
  "identifier": "com.casualras.host",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Casual RAS — Host",
        "url": "index.html",
        "width": 560,
        "height": 420,
        "resizable": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "focus": false,
        "skipTaskbar": true,
        "maximized": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false
  }
}
